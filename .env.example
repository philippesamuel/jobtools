# jobtools configuration — copy to .env and adjust

# Base path to your local Google Drive Bewerbungen folder
# JT_BASE_PATH=~/Library/CloudStorage/GoogleDrive-you@gmail.com/My Drive/03_Work/03_Bewerbungen

# Manifest filename (default: manifest.yaml)
# JT_MANIFEST_FILENAME=manifest.yaml

# LLM model string (pydantic-ai format)
# JT_LLM_MODEL=ollama:devstral-small-2:24b-cloud
# JT_LLM_MODEL=openai:gpt-4o
# JT_LLM_MODEL=anthropic:claude-sonnet-4-5

# Path to your awesome-cv repo
# JT_AWESOME_CV_DIR=~/Developer/philippe-awesome-cv

# Path to cookiecutter template repo
# JT_COOKIECUTTER_TEMPLATE=~/.config/jobtools/cookiecutter-jobapp

# Open $EDITOR for review after init/extract/tailor (default: true)
# JT_REVIEW=true

# Git init on scaffold (default: true)
# JT_GIT_INIT=true

# Attachment symlinks — override as JSON if your Zeugnisse paths differ
# JT_ATTACHMENTS={"BASF_Praktikantenzeugnis_2020.pdf": "/abs/path/to/file.pdf"}
